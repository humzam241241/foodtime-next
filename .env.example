# ─── Admin area (required for /admin) ──────────────────────────────
# The password you'll type on /admin/login
ADMIN_PASSWORD=change-this-to-something-strong

# Secret used to sign the admin session cookie. Must be >= 16 chars.
# Generate one with:  openssl rand -hex 32
ADMIN_SECRET=replace-with-a-long-random-string-at-least-16-chars

# ─── Vercel Blob (required for uploads + persisting hero image config) ───
# Auto-populated when you connect Vercel Blob via the Vercel dashboard
# (Storage → Create → Blob) and link the project with `vercel link`.
# Pull locally with:  vercel env pull .env.local
BLOB_READ_WRITE_TOKEN=

# ─── Email (already used by /api/contact, optional) ─────────────────
RESEND_API_KEY=
